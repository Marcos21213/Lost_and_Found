APP_NAME=Lost and Found Backend
APP_ENV=development
DEBUG=true

FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

DATABASE_PATH=data/lost_found.db

CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=lost_found_collection
VECTOR_SIMILARITY_THRESHOLD=0.6

JWT_SECRET_KEY=change-this-secret-key-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

UPLOAD_IMAGE_DIR=static/images
UPLOAD_IMAGE_URL_PREFIX=/static/images
MAX_IMAGE_SIZE_MB=2

LLM_KEY=
EMBEDDING_KEY=
MCP_API_BASE_URL=
MCP_SESSION_HEADER=X-MCP-Session-ID
MCP_CONTEXT_MAX_CHARS=4000
MCP_TIMEOUT_SECONDS=30
LLM_MODEL_NAME=
VECTOR_MODEL_NAME=
EMBEDDING_MODEL_NAME=
EMBEDDING_DIMENSION=384
